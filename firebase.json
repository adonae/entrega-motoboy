{
  "firestore": {
    "rules": "firestore.rules"
  },
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      ".firebaserc",
      ".gitignore",
      "LEIA-ME.md",
      "skills-lock.json",
      "firebase-debug.log",
      "**/.*",
      "**/node_modules/**"
    ]
  },
  "emulators": {
