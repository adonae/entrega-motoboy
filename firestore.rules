rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /entregas/{entregaId} {
      allow get: if true;
      allow list: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /lotes/{loteId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
